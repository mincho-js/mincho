{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vitest/importMeta", "vite/client"],
    
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path Aliases for Workspace Packages */
    "baseUrl": "../../",
    "paths": {
      "@examples/shared-component": ["examples/shared-component/src"],
      "@mincho-js/css": ["packages/css/src"]
    },

    "tsBuildInfoFile": "./.cache/typescript/tsbuildinfo-app"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css.ts"
  ]
}
